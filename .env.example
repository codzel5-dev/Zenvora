# Database — Prisma needs a valid SQLite URL for engine initialization
DATABASE_URL="file:./dev.db"

# Turso Database (production) — Get yours at https://turso.tech
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your_turso_auth_token_here"

# lmfiles.com API Key — Get yours at https://lmfiles.com
LMFILES_API_KEY="lmf_your_api_key_here"

# YepAPI — AI-powered file analysis
YEPAPI_KEY="yep_sk_your_api_key_here"

# Site Configuration
NEXT_PUBLIC_SITE_URL="https://zenvoora.vercel.app"
NEXT_PUBLIC_MAX_FILE_SIZE=104857600
