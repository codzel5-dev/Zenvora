# Database — Turso (libSQL)
# Get your credentials from https://turso.tech
DATABASE_URL="libsql://your-db-name-your-org.turso.io"
DATABASE_AUTH_TOKEN="your_turso_auth_token_here"

# For local development (optional fallback):
# DATABASE_URL="file:./dev.db"

# lmfiles.com API Key — Get yours at https://lmfiles.com
LMFILES_API_KEY="lmf_your_api_key_here"

# Site Configuration
NEXT_PUBLIC_SITE_NAME="FileVault"
NEXT_PUBLIC_SITE_URL="https://filevault.app"
NEXT_PUBLIC_MAX_FILE_SIZE=104857600
