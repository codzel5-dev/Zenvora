generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UploadedFile {
  id            String    @id @default(cuid())
  fileName      String
  originalName  String
  fileUrl       String
  fileSize      Int
  mimeType      String
  uploaderIp    String
  lmfilesId     String?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime?
  downloadCount Int       @default(0)

  // Smart File Platform fields
  description   String    @default("")
  tags          String    @default("")
  category      String    @default("general")
  aiSummary     String    @default("")
  thumbnailUrl  String    @default("")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String
  imageUrl  String   @default("")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model ConversionJob {
  id             String    @id @default(cuid())
  jobId          String    @unique   // CloudConvert job ID
  status         String    @default("waiting")  // waiting | processing | finished | error
  percent        Int       @default(0)
  inputFileName  String
  inputMimeType  String
  outputFormat   String
  fileUrl        String    @default("")  // Input file URL
  downloadUrl    String?   // Output download URL (set when finished)
  outputFilename String?   // Output file name
  error          String?   // Error message if failed
  keyLabel       String?   // Which API key was used
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
